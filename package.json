{
  "name": "marknative-workspace",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter 'marknative' build",
    "typecheck": "bun run --filter 'marknative' typecheck",
    "test": "bun --cwd packages/marknative test",
    "bench": "bun run --filter 'marknative' bench",
    "docs:dev": "bun --cwd packages/marknative-docs run dev",
    "docs:build": "bun --cwd packages/marknative-docs run build",
    "docs:preview": "bun --cwd packages/marknative-docs run preview"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "bun-types": "latest",
    "typescript": "^5"
  }
}
